import pandas as pd

# 1. Load STRICTLY Train data
train = pd.read_csv("./data/processed/train.csv")

# 2. Target Definition
target_col = "default payment next month"
print(f"Target prevalence (Base Rate): {train[target_col].mean():.4f}")

# 3. Leakage Audit
# Drop ID. It is a monotonic integer tracking chronological order. 
# Tree-based models will split on ID and overfit the temporal axis, causing catastrophic failure in OOT Test.
train = train.drop(columns=["ID"])

# Define operational scope: Behavioral Scoring.
# We predict October default using data up to September.
# PAY_0 (September status) to PAY_6 (April status) are valid historical predictors.
# If the operational scope was Origination Scoring (predicting default at the time the card is issued),
# all PAY_*, BILL_AMT_*, and PAY_AMT_* columns would be severe data leakage and must be dropped.

print("Features retained for Behavioral Scoring:")
print(train.columns.tolist())